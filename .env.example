# =========================================================================
#  Frederiks Bedrijfskleding: omgevingsvariabelen
#  Kopieer naar .env.local (lokaal) en zet dezelfde waarden in
#  Vercel -> Project -> Settings -> Environment Variables.
#  Commit NOOIT .env.local of echte sleutels naar git.
# =========================================================================

# Basis-URL van de site (canonical, sitemap, e-mails)
NEXT_PUBLIC_SITE_URL=https://www.frederiksbedrijfskleding.nl

# --- E-mail (Resend): voor het advies-/offerteformulier ---
# Zonder key werkt het formulier gewoon; er wordt dan geen mail verstuurd
# (handig voor lokaal/preview). Verifieer het domein in Resend voor livegang.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL="Frederiks Bedrijfskleding <offerte@frederiksbedrijfskleding.nl>"
LEAD_NOTIFY_EMAIL=info@frederiksbedrijfskleding.nl

# --- Analytics (GA4): optioneel, koppel aan cookie-consent vóór livegang ---
NEXT_PUBLIC_GA_ID=

# --- Leaddatabase (Supabase): optioneel, voor opslag + /dashboard ---
# Zonder deze waarden werkt het formulier gewoon (mail), maar wordt er niets
# opgeslagen en is /dashboard leeg/uitgeschakeld. De service-role key is GEHEIM
# en mag alleen in server-side env staan, nooit met NEXT_PUBLIC_ ervoor.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx
# Wachtwoord voor het interne lead-dashboard op /dashboard
DASHBOARD_PASSWORD=

# --- Klantportaal (Supabase Auth in de browser): publieke sleutels ---
# Deze twee zijn publiek (mogen in de client). Nodig om /portaal aan te zetten.
NEXT_PUBLIC_SUPABASE_URL=https://ldbyljadqququzoicyid.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
